<script>
(function () {
  var root = document.getElementById('ps-{{ section.id }}');
  if (!root) return;

  var slides = root.querySelectorAll('[data-ps-slide]');
  var thumbs = root.querySelectorAll('[data-ps-thumb]');
  var dots = root.querySelectorAll('[data-ps-dots] [data-index]');
  var accordions = root.querySelectorAll('[data-ps-accordion]');
  var current = 0;
  var activeGroup = null;

  function resetAccordion(acc) {
    acc.classList.remove('is-open');
  }

  function groupMatches(el) {
    if (!activeGroup) return true;
    return (el.dataset.group || '') === activeGroup;
  }

  function applyGroupVisibility() {
    thumbs.forEach(function (t) { t.style.display = groupMatches(t) ? '' : 'none'; });
    slides.forEach(function (s) { s.style.display = groupMatches(s) ? '' : 'none'; });
    dots.forEach(function (d) { d.style.display = groupMatches(d) ? '' : 'none'; });
    accordions.forEach(function (a) { a.style.display = groupMatches(a) ? null : 'none'; });
  }

  function showSlide(index) {
    if (!slides.length) return;
    current = (index + slides.length) % slides.length;
    slides.forEach(function (s) { s.classList.toggle('is-active', +s.dataset.index === current); });
    thumbs.forEach(function (t) { t.classList.toggle('is-active', +t.dataset.index === current); });
    dots.forEach(function (d) { d.classList.toggle('is-active', +d.dataset.index === current); });
    accordions.forEach(function (a) {
      a.classList.toggle('is-active', +a.dataset.index === current);
      resetAccordion(a);
    });
  }

  function firstIndexInGroup(nodeList) {
    for (var i = 0; i < nodeList.length; i++) {
      if (groupMatches(nodeList[i])) return +nodeList[i].dataset.index;
    }
    return 0;
  }

  function setGroup(group) {
    activeGroup = group || null;
    applyGroupVisibility();
    showSlide(firstIndexInGroup(slides));
  }

  thumbs.forEach(function (t) {
    t.addEventListener('click', function () { showSlide(+t.dataset.index); });
  });
  dots.forEach(function (d) {
    d.addEventListener('click', function () { showSlide(+d.dataset.index); });
  });
  var prevBtn = root.querySelector('[data-ps-prev]');
  var nextBtn = root.querySelector('[data-ps-next]');
  if (prevBtn) prevBtn.addEventListener('click', function () {
    var visible = Array.prototype.filter.call(slides, groupMatches);
    if (!visible.length) return;
    var idx = visible.findIndex(function (s) { return +s.dataset.index === current; });
    var nextEl = visible[(idx - 1 + visible.length) % visible.length];
    showSlide(+nextEl.dataset.index);
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    var visible = Array.prototype.filter.call(slides, groupMatches);
    if (!visible.length) return;
    var idx = visible.findIndex(function (s) { return +s.dataset.index === current; });
    var nextEl = visible[(idx + 1) % visible.length];
    showSlide(+nextEl.dataset.index);
  });

  var thumbsTrack = root.querySelector('[data-ps-thumbs-track]');
  var thumbsPrev = root.querySelector('[data-ps-thumbs-prev]');
  var thumbsNext = root.querySelector('[data-ps-thumbs-next]');
  function scrollThumbs(dir) {
    if (!thumbsTrack) return;
    thumbsTrack.scrollBy({ left: thumbsTrack.clientWidth * 0.8 * dir, behavior: 'smooth' });
  }
  if (thumbsPrev) thumbsPrev.addEventListener('click', function () { scrollThumbs(-1); });
  if (thumbsNext) thumbsNext.addEventListener('click', function () { scrollThumbs(1); });

  root.querySelectorAll('[data-ps-accordion-toggle]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var acc = btn.closest('[data-ps-accordion]');
      if (!acc) return;
      acc.classList.toggle('is-open');
    });
  });

  var modelCards = root.querySelectorAll('[data-ps-model]');
  var payNowEl = root.querySelector('[data-ps-pay-now]');
  var payCompareEl = root.querySelector('[data-ps-pay-compare]');
  var monthlyEl = root.querySelector('[data-ps-monthly]');
  var monthlyNoteEl = root.querySelector('[data-ps-monthly-note]');

  function selectModel(card) {
    modelCards.forEach(function (c) { c.classList.remove('is-selected'); });
    card.classList.add('is-selected');
    if (payNowEl) payNowEl.textContent = card.dataset.payNow || '';
    if (payCompareEl) payCompareEl.textContent = card.dataset.payCompare || '';
    if (monthlyEl) monthlyEl.textContent = card.dataset.monthly || '';
    if (monthlyNoteEl) monthlyNoteEl.textContent = card.dataset.monthlyNote || '';
    setGroup(card.dataset.group);
  }

  modelCards.forEach(function (card) {
    card.addEventListener('click', function () { selectModel(card); });
  });

  if (modelCards.length) {
    selectModel(modelCards[0]);
  } else {
    applyGroupVisibility();
  }
})();
</script>

