{%- comment -%}
  Section: Product Showcase (Gallery + Model Selector)
  File: sections/product-showcase.liquid
  Add via Theme Editor > Add section > "Product Showcase"
{%- endcomment -%}

<div class="ps-wrap" id="ps-{{ section.id }}">
  <div class="ps-grid">

    {%- comment -%} ===================== LEFT: GALLERY ===================== {%- endcomment -%}
    <div class="ps-gallery">
      <div class="ps-thumbs-row">
        <button type="button" class="ps-thumb-arrow ps-thumb-arrow--prev" data-ps-thumbs-prev aria-label="Previous thumbnails">
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="ps-thumbs" data-ps-thumbs-track>
          {%- assign ps_idx = -1 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' -%}
              {%- assign ps_idx = ps_idx | plus: 1 -%}
              <button type="button"
                      class="ps-thumb {% if ps_idx == 0 %}is-active{% endif %}"
                      data-ps-thumb
                      data-index="{{ ps_idx }}"
                      data-group="{{ block.settings.gallery_group }}"
                      aria-label="{{ block.settings.label | default: 'View image' | escape }}">
                {%- if block.settings.image -%}
                  {{ block.settings.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: block.settings.label }}
                {%- else -%}
                  <span class="ps-thumb-placeholder"></span>
                {%- endif -%}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <button type="button" class="ps-thumb-arrow ps-thumb-arrow--next" data-ps-thumbs-next aria-label="Next thumbnails">
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <div class="ps-preview">
        <button type="button" class="ps-arrow ps-arrow--prev" data-ps-prev aria-label="Previous image">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div class="ps-preview-stage">
          {%- assign ps_idx = -1 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' -%}
              {%- assign ps_idx = ps_idx | plus: 1 -%}
              <div class="ps-slide {% if ps_idx == 0 %}is-active{% endif %}" data-ps-slide data-index="{{ ps_idx }}" data-group="{{ block.settings.gallery_group }}">
                {%- if block.settings.image -%}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.label, class: 'ps-slide-img' }}
                {%- endif -%}

                {%- if block.settings.overlay_layout == 'centered' and block.settings.overlay_title != blank -%}
                  <div class="ps-slide-overlay ps-slide-overlay--centered">
                    <div class="ps-overlay-headline">{{ block.settings.overlay_title }}</div>
                    {%- if block.settings.overlay_caption != blank -%}
                      <div class="ps-overlay-subline">{{ block.settings.overlay_caption }}</div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <button type="button" class="ps-arrow ps-arrow--next" data-ps-next aria-label="Next image">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div class="ps-dots" data-ps-dots>
          {%- assign ps_idx = -1 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' -%}
              {%- assign ps_idx = ps_idx | plus: 1 -%}
              <span class="ps-dot {% if ps_idx == 0 %}is-active{% endif %}" data-index="{{ ps_idx }}" data-group="{{ block.settings.gallery_group }}"></span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="ps-accordion-wrap">
        {%- assign ps_idx = -1 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery_image' -%}
            {%- assign ps_idx = ps_idx | plus: 1 -%}
            {%- if block.settings.accordion_title != blank or block.settings.accordion_text != blank -%}
              <div class="ps-accordion {% if ps_idx == 0 %}is-active{% endif %}" data-ps-accordion data-index="{{ ps_idx }}" data-group="{{ block.settings.gallery_group }}">
                <button type="button" class="ps-accordion-head" data-ps-accordion-toggle>
                  <span class="ps-accordion-main">
                    <span class="ps-accordion-title">
                      {%- if block.settings.accordion_icon -%}
                        <span class="ps-accordion-icon">{{ block.settings.accordion_icon | image_url: width: 40 | image_tag: alt: '' }}</span>
                      {%- else -%}
                        <span class="ps-accordion-icon">
                          <svg viewBox="0 0 24 24" width="16" height="16"><path d="M13.5 4.5a1.75 1.75 0 100 3.5 1.75 1.75 0 000-3.5zM5 19l3.5-6 3 2 3-5.5L19 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                      {%- endif -%}
                      <strong>{{ block.settings.accordion_title }}</strong>
                    </span>
                    {%- if block.settings.accordion_text != blank -%}
                      <span class="ps-accordion-body">
                        <span class="ps-accordion-body-text">{{ block.settings.accordion_text }}</span>
                      </span>
                    {%- endif -%}
                  </span>
                  <span class="ps-accordion-plus" data-ps-accordion-plus>+</span>
                </button>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ===================== RIGHT: DETAILS ===================== {%- endcomment -%}
    <div class="ps-details">

      <div class="ps-top-price-row">
        <div class="ps-top-price">
          {%- if section.settings.compare_price != blank -%}
            <span class="ps-compare-price">{{ section.settings.compare_price }}</span>
          {%- endif -%}
          <span class="ps-sep">or</span>
          <span class="ps-financing">{{ section.settings.financing_price }}</span>
        </div>
        <a href="{{ section.settings.buy_now_link | default: '#' }}" class="ps-buy-btn ps-buy-btn--sm">{{ section.settings.buy_now_text | default: 'BUY NOW' }}</a>
      </div>

      <div class="ps-savings-banner">
        {{ section.settings.savings_banner_html }}
      </div>
      <h1 class="ps-title">{{ section.settings.product_title }}</h1>
      <div class="ps-stock-row">
        {%- if section.settings.stock_label != blank -%}<span class="ps-stock">{{ section.settings.stock_label }}</span>{%- endif -%}
        {%- if section.settings.award_label != blank -%}<span class="ps-award">{{ section.settings.award_label }}</span>{%- endif -%}
      </div>

      <div class="ps-rating-row">
        <span class="ps-stars" aria-hidden="true">
          {%- assign full = section.settings.rating | times: 1 -%}
          {%- for i in (1..5) -%}
            {%- if i <= full -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </span>
        <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="ps-review-count">{{ section.settings.review_count }} Reviews</a>
        <span class="ps-review-sep">|</span>
        <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="ps-review-link">See reviews summary</a>
      </div>

      <p class="ps-description">{{ section.settings.description }}</p>

      {%- if section.settings.whats_included != blank -%}
        <details class="ps-whats-included">
          <summary>What's included</summary>
          <div>{{ section.settings.whats_included }}</div>
        </details>
      {%- endif -%}

      {%- if section.settings.promo_html != blank -%}
        <div class="ps-promo">
          <div class="ps-promo-icon">
            <svg viewBox="0 0 24 24" width="16" height="16"><path d="M4 4h10l6 6v10H4z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
          </div>
          <div class="ps-promo-text">{{ section.settings.promo_html }}</div>
          <svg class="ps-promo-arrow" viewBox="0 0 24 24" width="16" height="16"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
      {%- endif -%}

      <div class="ps-select-model">
        <h3>{{ section.settings.select_model_label | default: 'SELECT YOUR MODEL' }}</h3>

        <div class="ps-model-list" data-ps-models>
          {%- assign ps_model_idx = -1 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'model_option' -%}
              {%- assign ps_model_idx = ps_model_idx | plus: 1 -%}
              <button type="button"
                      class="ps-model-card {% if ps_model_idx == 0 %}is-selected{% endif %}"
                      data-ps-model
                      data-group="{{ block.settings.gallery_group }}"
                      data-pay-now="{{ block.settings.pay_now_price }}"
                      data-pay-compare="{{ block.settings.compare_price }}"
                      data-monthly="{{ block.settings.monthly_price }}"
                      data-monthly-note="{{ block.settings.monthly_note | escape }}">
                {%- if block.settings.savings_badge != blank -%}
                  <span class="ps-model-badge">{{ block.settings.savings_badge }}</span>
                {%- endif -%}
                <span class="ps-model-row">
                  {%- if block.settings.image -%}
                    <span class="ps-model-img">{{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.name }}</span>
                  {%- endif -%}
                  <span class="ps-model-info">
                    <span class="ps-model-name">{{ block.settings.name }}</span>
                    <span class="ps-model-specs">{{ block.settings.specs | newline_to_br }}</span>
                  </span>
                  <span class="ps-model-price">
                    {%- if block.settings.compare_price != blank -%}
                      <span class="ps-model-compare">{{ block.settings.compare_price }}</span>
                    {%- endif -%}
                    <span class="ps-model-current">{{ block.settings.pay_now_price }}</span>
                  </span>
                </span>
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="ps-compare-links">
          <a href="{{ section.settings.compare_models_link | default: '#' }}">{{ section.settings.compare_models_text | default: 'COMPARE MODELS' }}</a>
          <a href="{{ section.settings.view_specs_link | default: '#' }}">{{ section.settings.view_specs_text | default: 'VIEW PERFORMANCE SPECS' }}</a>
        </div>
      </div>

      <div class="ps-pay-row">
        <div class="ps-pay-col">
          <span class="ps-pay-label">PAY NOW</span>
          <span class="ps-pay-value" data-ps-pay-now>{{ section.settings.default_pay_now }}</span>
          <span class="ps-pay-compare" data-ps-pay-compare>{{ section.settings.default_compare }}</span>
        </div>
        <div class="ps-pay-divider"></div>
        <div class="ps-pay-col">
          <span class="ps-pay-label">PAY OVER TIME</span>
          <span class="ps-pay-value" data-ps-monthly>{{ section.settings.default_monthly }}</span>
          <span class="ps-pay-note" data-ps-monthly-note>{{ section.settings.default_monthly_note }}</span>
        </div>
      </div>

      <a href="{{ section.settings.buy_now_link | default: '#' }}" class="ps-buy-btn ps-buy-btn--lg">{{ section.settings.buy_now_text | default: 'BUY NOW' }}</a>

      {%- if section.settings.benefits_heading != blank or section.blocks.size > 0 -%}
        <div class="ps-benefits-card">
          <h4>{{ section.settings.benefits_heading }}</h4>
          {%- if section.settings.benefits_subtext != blank -%}
            <p class="ps-benefits-sub">{{ section.settings.benefits_subtext }}</p>
          {%- endif -%}
          <div class="ps-benefits-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'benefit' -%}
                <div class="ps-benefit-item">
                  <svg viewBox="0 0 24 24" width="14" height="14"><path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{{ block.settings.text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if section.settings.benefits_link_text != blank -%}
            <a href="{{ section.settings.benefits_link | default: '#' }}" class="ps-benefits-link">{{ section.settings.benefits_link_text }} &rsaquo;</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.power_heading != blank -%}
        <div class="ps-power-block">
          <h4>{{ section.settings.power_heading }}</h4>
          <p>{{ section.settings.power_text }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');
  #ps-{{ section.id }} {
    --ps-ink: #14202e;
    --ps-muted: #5b6672;
    --ps-line: #e3e6e9;
    --ps-blue: #0f5cc9;
    --ps-navy: #14202e;
    --ps-red: #c8102e;
    --ps-bg-soft: #f6f7f8;
      font-family: "Poppins", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;    color: var(--ps-ink);
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 2% 7%;
    box-sizing: border-box;
  }
  #ps-{{ section.id }} *, #ps-{{ section.id }} *::before, #ps-{{ section.id }} *::after { box-sizing: border-box; }
  #ps-{{ section.id }} .ps-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.9fr) minmax(0, 0.9fr);
    gap: clamp(20px, 3vw, 48px);
    align-items: start;
  }
  @media (min-width: 1024px) {
    #ps-{{ section.id }} .ps-gallery,
    #ps-{{ section.id }} .ps-details {
      position: sticky;
      top: 24px;
      align-self: start;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      scroll-behavior: smooth;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    #ps-{{ section.id }} .ps-gallery::-webkit-scrollbar,
    #ps-{{ section.id }} .ps-details::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }
    #ps-{{ section.id }} .ps-gallery { overflow: visible; max-height: none; }
  }

  /* ---------- GALLERY ---------- */
  #ps-{{ section.id }} .ps-gallery { display: grid; grid-template-columns: clamp(52px, 6vw, 68px) 1fr; column-gap: clamp(8px, 1.5vw, 14px); row-gap: 0; }
  #ps-{{ section.id }} .ps-thumbs-row { display: flex; flex-direction: column; }
  #ps-{{ section.id }} .ps-thumbs { display: flex; flex-direction: column; gap: clamp(6px, 1vw, 10px); }
  #ps-{{ section.id }} .ps-thumb-arrow { display: none; }
  #ps-{{ section.id }} .ps-thumb {
    border: 1px solid var(--ps-line); background: #fff; border-radius: 4px; padding: 0;
    width: 100%; aspect-ratio: 1/1; overflow: hidden; cursor: pointer; display: block;
    transition: border-color .15s ease;
  }
  #ps-{{ section.id }} .ps-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #ps-{{ section.id }} .ps-thumb.is-active { border-color: var(--ps-navy); border-width: 2px; }
  #ps-{{ section.id }} .ps-thumb-placeholder { display: block; width: 100%; height: 100%; background: var(--ps-bg-soft); }

  #ps-{{ section.id }} .ps-preview { position: relative; border-radius: 4px; overflow: hidden; }
  #ps-{{ section.id }} .ps-preview-stage { position: relative; width: 100%; aspect-ratio: 5/5; }
  #ps-{{ section.id }} .ps-slide { position: absolute; inset: 0; opacity: 0; visibility: hidden; transition: opacity .25s ease; }
  #ps-{{ section.id }} .ps-slide.is-active { opacity: 1; visibility: visible; }
  #ps-{{ section.id }} .ps-slide-img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Centered full-bleed text overlay (marketing / lifestyle hero slides only) */
  #ps-{{ section.id }} .ps-slide-overlay--centered {
    position: absolute; inset: 0; left: 0; top: 0; max-width: none; background: linear-gradient(180deg, rgba(10,14,20,.6) 0%, rgba(10,14,20,.15) 45%, rgba(10,14,20,0) 65%);
    display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
    text-align: center; padding: clamp(20px, 4vw, 40px) clamp(16px, 6vw, 60px); border-radius: 0;
    color: #fff;
  }
  #ps-{{ section.id }} .ps-overlay-headline {
    font-size: clamp(16px, 2.4vw, 24px); font-weight: 800; letter-spacing: .01em; line-height: 1.25; text-transform: uppercase;
  }
  #ps-{{ section.id }} .ps-overlay-subline {
    margin-top: 6px; font-size: clamp(12px, 1.4vw, 15px); font-weight: 500; line-height: 1.4; opacity: .95; max-width: 34ch;
  }

  #ps-{{ section.id }} .ps-arrow {
    position: absolute; top: 50%; transform: translateY(-50%); width: 34px; height: 34px; border-radius: 10%;
    background: #3333332c; border: 1px solid var(--ps-line); display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: #fff; z-index: 3;
  }
  #ps-{{ section.id }} .ps-arrow--prev { left: 14px; }
  #ps-{{ section.id }} .ps-arrow--next { right: 14px; }
  #ps-{{ section.id }} .ps-arrow:hover { background: #fff; color:#000; }

  #ps-{{ section.id }} .ps-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(20,32,46,.3); cursor: pointer; }
  #ps-{{ section.id }} .ps-dot.is-active { background: var(--ps-navy); }

  #ps-{{ section.id }} .ps-accordion-wrap {
    grid-column: 2;
    margin-top: 0;
  }
  #ps-{{ section.id }} .ps-accordion {
    display: none;
    background: #f7f1e9;
    border-radius: 2px;
    padding: clamp(12px, 2vw, 16px) clamp(14px, 2vw, 18px);
  }
  #ps-{{ section.id }} .ps-accordion.is-active { display: block; }
  #ps-{{ section.id }} .ps-accordion-head {
    display: flex; align-items: center; justify-content: space-between; gap: 14px;
    width: 100%; background: none; border: none; padding: 0; margin: 0; cursor: pointer;
    font-family: inherit; text-align: left;
  }
  #ps-{{ section.id }} .ps-accordion-main {
    display: flex; flex-direction: column; gap: 4px; min-width: 0; flex: 1;
  }
  #ps-{{ section.id }} .ps-accordion-title { display: flex; align-items: center; gap: 8px; font-size: clamp(13px, 1.4vw, 14.5px); font-weight: 700; color: var(--ps-ink); }
  #ps-{{ section.id }} .ps-accordion-title strong { font-weight: 700; }
  #ps-{{ section.id }} .ps-accordion-icon { flex-shrink: 0; display: flex; color: var(--ps-ink); }
  #ps-{{ section.id }} .ps-accordion-icon img { display: block; width: 18px; height: 18px; object-fit: contain; }
  #ps-{{ section.id }} .ps-accordion-plus {
    font-size: 22px; line-height: 1; color: var(--ps-ink); font-weight: 400;
    width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    transition: transform .15s ease;
  }
  #ps-{{ section.id }} .ps-accordion-body {
    /* Collapsed: a 0fr row with the text bottom-anchored inside it, so only
       the very bottom of the (clipped) text shows -- i.e. just the first
       line, matching the old preview. Opening grows the row to 1fr; because
       the text stays anchored to the bottom the whole time, the reveal
       animates as new lines appearing ABOVE, growing upward from the
       bottom edge, instead of the ordinary top-down expand. */
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .3s ease;
    font-size: clamp(12.5px, 1.3vw, 13.5px); line-height: 1.5; color: var(--ps-muted);
  }
  #ps-{{ section.id }} .ps-accordion.is-open .ps-accordion-body {
    grid-template-rows: 1fr;
  }
  #ps-{{ section.id }} .ps-accordion-body-text {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    min-height: 0;
  }
  #ps-{{ section.id }} .ps-accordion.is-open .ps-accordion-plus { transform: rotate(45deg); }

  /* ---------- DETAILS ---------- */
  #ps-{{ section.id }} .ps-top-price-row { display: flex; align-items: center; justify-content: flex-end; gap: 14px; border-bottom: 1px solid var(--ps-line); padding-bottom: 16px; flex-wrap: wrap; }
  #ps-{{ section.id }} .ps-top-price { font-size: 13px; color: var(--ps-muted); }
  #ps-{{ section.id }} .ps-compare-price { text-decoration: line-through; margin-right: 6px; }
  #ps-{{ section.id }} .ps-financing { color: var(--ps-ink); font-weight: 600; }

  #ps-{{ section.id }} .ps-buy-btn {
    display: inline-flex; align-items: center; justify-content: center; background: var(--ps-navy); color: #fff;
    font-weight: 700; letter-spacing: .04em; text-decoration: none; border-radius: 3px; border: none; cursor: pointer;
    text-align: center;
  }
  #ps-{{ section.id }} .ps-buy-btn--sm { padding: 10px clamp(16px, 3vw, 30px); font-size: 12.5px; white-space: nowrap; }
  #ps-{{ section.id }} .ps-buy-btn--lg { width: 100%; padding: 16px; font-size: 14px; margin-top: 18px; }
  #ps-{{ section.id }} .ps-buy-btn:hover { background: #23364d; }

  #ps-{{ section.id }} .ps-savings-banner { font-size: clamp(11px, 1.1vw, 12px); font-weight: 700; letter-spacing: .03em; color: var(--ps-navy); margin: 0; }

  #ps-{{ section.id }} .ps-title { font-size: clamp(20px, 2.4vw, 26px); font-weight: 800; letter-spacing: .01em; margin: 0; }

  #ps-{{ section.id }} .ps-stock-row { display: flex; gap: 1px; font-size: 11.5px; font-weight: 700; letter-spacing: .03em; color: var(--ps-muted); margin-bottom: 8px; flex-direction: column; }

  #ps-{{ section.id }} .ps-rating-row { display: flex; align-items: center; gap: 8px; font-size: 13px; margin-bottom: 14px; flex-wrap: wrap; }
  #ps-{{ section.id }} .ps-stars { color: #14202e; letter-spacing: 2px; font-size: 16px; }
  #ps-{{ section.id }} .ps-review-count, #ps-{{ section.id }} .ps-review-link { color: var(--ps-blue); text-decoration: none; }
  #ps-{{ section.id }} .ps-review-count:hover, #ps-{{ section.id }} .ps-review-link:hover { text-decoration: underline; }
  #ps-{{ section.id }} .ps-review-sep { color: var(--ps-line); }

  #ps-{{ section.id }} .ps-description { font-size: 14.5px; line-height: 1.6; color: var(--ps-ink); margin: 0 0 14px; }

  #ps-{{ section.id }} .ps-whats-included { font-size: 13px; margin-bottom: 16px; }
  #ps-{{ section.id }} .ps-whats-included summary { cursor: pointer; font-weight: 700; }

  #ps-{{ section.id }} .ps-promo {
